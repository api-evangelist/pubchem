{
  "title": "Get Compound by Name",
  "description": "Look up a compound by chemical name (glucose) and retrieve its basic properties.",
  "request": {
    "method": "GET",
    "url": "https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/name/glucose/property/MolecularFormula,MolecularWeight,InChIKey,IUPACName/JSON",
    "headers": {
      "Accept": "application/json"
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "PropertyTable": {
        "Properties": [
          {
            "CID": 5793,
            "MolecularFormula": "C6H12O6",
            "MolecularWeight": "180.16",
            "InChIKey": "WQZGKKKJIJFFOK-GASJEMHNSA-N",
            "IUPACName": "(2R,3S,4R,5R)-2,3,4,5,6-pentahydroxyhexanal"
          }
        ]
      }
    }
  }
}
